# Karibu environment variables. Placeholders only. Never commit real secrets.
# Copy to .env (gitignored) and fill in real values.

# Agent wallet. Created in Phase 0 with cast wallet new. The private key lives
# only in .env and is never printed, logged, or committed.
AGENT_ADDRESS=0xYourAgentPublicAddress
AGENT_PRIVATE_KEY=0xYourAgentPrivateKey

# Networks. sourceRef: docs/FACTS.md section 1.
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
CELO_MAINNET_RPC=https://forno.celo.org

# thirdweb x402. Created by drew in the thirdweb dashboard.
THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key
THIRDWEB_SERVER_WALLET_ADDRESS=0xYourThirdwebServerWallet

# Block explorer API key (Celoscan).
CELOSCAN_API_KEY=your_celoscan_api_key

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Deployed KaribuNotary addresses. Filled after deploy. sourceRef: docs/FACTS.md.
KARIBU_NOTARY_ADDRESS_SEPOLIA=
KARIBU_NOTARY_ADDRESS_MAINNET=
